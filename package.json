{
  "name": "sop-to-skill",
  "version": "1.0.0",
  "description": "Convert SOP documents to executable AI Agent Skills",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "sop-to-skill": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:e2e": "bash ci/e2e-smoke.sh",
    "test:api-smoke": "bash ci/api-smoke.sh",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "sop",
    "skill",
    "ai-agent",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.10",
    "clipanion": "^3.2.1",
    "js-yaml": "^4.1.0",
    "mammoth": "^1.6.0",
    "marked": "^12.0.0",
    "pdf-parse": "^1.1.1",
    "typanion": "^3.14.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
